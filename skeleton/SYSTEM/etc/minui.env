export BOOTCONF="/boot/batocera-boot.conf"
export REBOOT_FLAG=/var/run/retroarch-launcher

export PLATFORM="rg35xx"
export SDCARD_PATH="/userdata"
export SDCARD_SYS="/opt/minui"
export BIOS_PATH="$SDCARD_PATH/Bios"
export SAVES_PATH="$SDCARD_PATH/Saves"
export SYSTEM_PATH="$SDCARD_SYS"
export CORES_PATH="$SDCARD_PATH/Cores"
export USERDATA_PATH="$SDCARD_PATH/Profile"
export USERCONF_PATH="$USERDATA_PATH/configs"
export SHARED_USERDATA_PATH="$USERDATA_PATH/shared"
export LOGS_PATH="$USERDATA_PATH/logs"
export DATETIME_PATH="$SHARED_USERDATA_PATH/datetime.txt"
export SYSTEM_BIN="$SYSTEM_PATH/bin"

export PATH=$SDCARD_SYS/bin:$PATH
export HOME="$USERDATA_PATH"

#######################################

export CPU_SPEED_MENU=504000
export CPU_SPEED_LOW=756000
export CPU_SPEED_GAME=1296000
export CPU_SPEED_PERF=1488000

#######################################

# export SDL_VSYNC=1
export SDL_RENDER_DRIVER=opengles2

#######################################
export SDL_GAMECONTROLLERCONFIG_FILE="$USERCONF_PATH/gamecontrollerdb.txt"
export SDL_GAMECONTROLLERCONFIG=$(grep "RG35XX" "$SDL_GAMECONTROLLERCONFIG_FILE")

