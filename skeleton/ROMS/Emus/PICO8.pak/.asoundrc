# Obligamos al hardware a fijarse en 48000Hz y 2 canales
pcm.dmixer {
    type dmix
    ipc_key 1024
    slave {
        pcm "hw:0,0"
        rate 44100
        channels 2
    }
}

# El control de volumen va hacia el dmixer
pcm.softvol {
    type softvol
    slave.pcm "dmixer"
    control {
        name "Master"
        card 0
    }
    min_dB -51.0
    max_dB 0.0
    resolution 100
}

# El dispositivo por defecto va al volumen
pcm.!default {
    type plug
    slave.pcm "softvol"
}
